# Groq — free at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# GitHub OAuth App — github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=...

# Optional: personal token for higher API rate limits (no scopes needed)
GITHUB_TOKEN=ghp_...
